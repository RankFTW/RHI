                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailDxvkLabel" x:FieldModifier="internal" Grid.Column="0" Text="DXVK" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DetailDxvkStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"
                                               PointerPressed="DetailDxvkStatus_PointerPressed"
                                               PointerEntered="LinkText_PointerEntered" PointerExited="LinkText_PointerExited"/>
                                    <Button x:Name="DetailDxvkInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="DxvkInfoButton_Click"/>
                                    <Button x:Name="DetailDxvkInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallDxvkButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"/>
                                    <Button x:Name="DetailDxvkConfBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="DxvkCogButton_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="DXVK Settings">
                                        <TextBlock Text="⚙" FontSize="14" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailDxvkDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallDxvkButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove DXVK" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- No mod message -->
                                <Border x:Name="DetailNoModMsg" x:FieldModifier="internal" Visibility="Collapsed"
                                        Background="{StaticResource AccentPurpleBgBrush}" CornerRadius="8" Padding="12,8"
                                        BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="No RenoDX mod available for this game"
                                               FontSize="12" Foreground="{StaticResource TextDisabledBrush}" TextAlignment="Center"/>
                                </Border>

                                <!-- Progress bars -->
                                <StackPanel x:Name="DetailProgressSection" Spacing="4">
                                    <ProgressBar x:Name="DetailRefProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRefMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <ProgressBar x:Name="DetailRsProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentTealDimBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRsMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <ProgressBar x:Name="DetailUlProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailUlMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailDcProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailDcMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailOsProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailOsMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailDofFixProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailDofFixMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailDxvkProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailDxvkMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailRdxProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRdxMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailLumaProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentGreenBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailLumaMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentGreenBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Game Overrides section ── -->
                        <Border x:Name="OverridesContainer" x:FieldModifier="internal"
                                Background="{StaticResource SurfaceComponentTableBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                Padding="14,12" Visibility="Collapsed">
                            <StackPanel x:Name="OverridesPanel" x:FieldModifier="internal" Spacing="6"/>
                        </Border>

                        <!-- ── Nvidia Profile Overrides section ── -->
                        <Border x:Name="NvidiaProfileContainer" x:FieldModifier="internal"
                                Background="{StaticResource SurfaceComponentTableBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                Padding="14,12" Visibility="Collapsed">
                            <StackPanel x:Name="NvidiaProfilePanel" x:FieldModifier="internal" Spacing="6"/>
                        </Border>

                        <!-- ── Management section (folder, reset, report) ── -->
                        <Border x:Name="ManagementContainer" x:FieldModifier="internal"
                                Background="{StaticResource SurfaceComponentTableBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                Padding="14,12" Visibility="Collapsed">
                            <StackPanel x:Name="ManagementPanel" x:FieldModifier="internal" Spacing="6"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                    <!-- Compact Nav Arrows — overlaid on content area, visible only in Compact mode -->
                    <Button x:Name="CompactNavLeft"
                            Content="◀" Click="CompactNavLeft_Click"
                            VerticalAlignment="Center" HorizontalAlignment="Left"
                            Canvas.ZIndex="1"
                            Visibility="{x:Bind ViewModel.CompactViewVisibility, Mode=OneWay}"
                            Background="{StaticResource SurfaceInputBrush}"
                            Foreground="{StaticResource AccentTealBrush}"
                            BorderBrush="{StaticResource AccentTealBorderBrush}" BorderThickness="1"
                            CornerRadius="8" FontSize="18"
                            Padding="8,16" Margin="4,0"/>

                    <Button x:Name="CompactNavRight"
                            Content="▶" Click="CompactNavRight_Click"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            Canvas.ZIndex="1"
                            Visibility="{x:Bind ViewModel.CompactViewVisibility, Mode=OneWay}"
                            Background="{StaticResource SurfaceInputBrush}"
                            Foreground="{StaticResource AccentTealBrush}"
                            BorderBrush="{StaticResource AccentTealBorderBrush}" BorderThickness="1"
                            CornerRadius="8" FontSize="18"
                            Padding="8,16" Margin="0,0,4,0"/>

                    <!-- Skeleton detail panel overlay (removed programmatically after first load) -->
                    <ScrollViewer x:Name="SkeletonDetailScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Visibility="Visible">
                        <StackPanel x:Name="SkeletonDetailPanel" Spacing="16"
                                    Padding="24,18,24,24"/>
                    </ScrollViewer>

                </Grid>
            </Grid>

            <!--  SETTINGS PANEL  -->
            <Grid x:Name="SettingsPanel" x:FieldModifier="internal" Visibility="Collapsed" Background="{StaticResource SurfaceBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back button bar -->
                <Border Grid.Row="0" Padding="24,12,24,10" Background="Transparent"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button x:Name="SettingsBackBtn" Content="← Back to Games"
                                Click="SettingsBack_Click"
                                Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable settings content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="32,24,32,40" Spacing="14" MaxWidth="800"
                                HorizontalAlignment="Center">

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 1: GAME LIBRARY
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="Game Library" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Add Game -->
                                <Grid Grid.Column="0" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Add Game" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Manually add a game that wasn't automatically detected. Select the game's exe and you'll be asked to name it."/>
                                    </StackPanel>
                                    <Button Grid.Row="1" x:Name="AddGameBtn" Content="Add Game"
                                            Click="AddGameButton_Click"
                                            Background="{StaticResource AccentGreenBgBrush}" Foreground="{StaticResource AccentGreenBrush}"
                                            BorderBrush="{StaticResource AccentGreenBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,7" FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Manually add a game folder"/>
                                </Grid>

                                <!-- Divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch" Margin="12,0,12,0"/>

                                <!-- Right: Check For Updates -->
                                <Grid Grid.Column="2" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Check For Updates" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Fetches the latest manifest data and checks all components for available updates. Bypasses the 4-hour cooldown."/>
                                    </StackPanel>
                                    <Button Grid.Row="1" x:Name="CheckForUpdatesBtn" Content="Check For Updates"
                                            Click="CheckForUpdatesButton_Click"
                                            Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,7" FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Check all components and the app for available updates"/>
                                </Grid>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 2: RESHADE & DISPLAY
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="ReShade &amp; Display" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- ── Left: Screenshots & Hotkeys ── -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Screenshots &amp; Hotkeys" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Screenshot save path and ReShade key bindings applied to all managed reshade.ini files."/>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch" Margin="12,0,12,0"/>

                                <!-- ── Right: HDR & Peak Brightness ── -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="HDR &amp; Peak Brightness" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Peak brightness (nits) written to reshade.ini presets. HDR auto-toggle enables Windows HDR on game launch and disables on exit."/>
                                </StackPanel>

                                <!-- Row 1 Left: Screenshot path + Open -->
                                <Grid Grid.Row="1" Grid.Column="0" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ScreenshotPathBox" x:FieldModifier="internal"
                                                 PlaceholderText="D:\Screenshots"
                                                 FontSize="12" Padding="12,8,36,8"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"/>
                                        <Button Click="BrowseScreenshotPath_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="8,6" MinWidth="0" MinHeight="0"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                ToolTipService.ToolTip="Pick a folder for screenshots">
                                            <FontIcon Glyph="&#xED25;" FontSize="14"
                                                      Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </Button>
                                    </Grid>
                                    <Button Grid.Column="1" Content="Open" Click="OpenScreenshotFolder_Click"
                                            Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,6" FontSize="12"
                                            ToolTipService.ToolTip="Open the screenshot folder in Explorer"/>
                                </Grid>

                                <!-- Row 1 Right: Peak Nits -->
                                <Grid Grid.Row="1" Grid.Column="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Peak Nits" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" x:Name="PeakNitsAutoBtn"
                                            Content="Auto" Click="PeakNitsAuto_Click"
                                            Background="{StaticResource AccentBlueBgBrush}"
                                            Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="10,5" FontSize="12"
                                            ToolTipService.ToolTip="Reads your monitor's peak brightness automatically."/>
                                    <TextBox Grid.Column="2" x:Name="PeakNitsBox" x:FieldModifier="internal"
                                             PlaceholderText="nits" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             Background="{StaticResource SurfaceInputBrush}"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}"
                                             KeyDown="PeakNitsBox_KeyDown"/>
                                    <Button Grid.Column="3" Content="⚙" Click="PeakNitsCog_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource ChipTextBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8,4" MinWidth="0" MinHeight="0"
                                            FontSize="12" VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Configure which presets receive the global peak nits value."/>
                                </Grid>

                                <!-- Row 2 Left: Overlay key | Screenshot key | Per-Game Folders combo -->
                                <Grid Grid.Row="2" Grid.Column="0" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="Overlay key" Margin="0,0,0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="Screenshot key" Margin="0,0,0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="Subfolders" Margin="0,0,0,3"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="HotkeyBox" x:FieldModifier="internal"
                                             PlaceholderText="Press a key..." IsReadOnly="True" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             Background="{StaticResource SurfaceInputBrush}"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}"
                                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                    <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="ScreenshotHotkeyBox" x:FieldModifier="internal"
                                                 PlaceholderText="Press a key..." IsReadOnly="True" FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                                 PreviewKeyDown="ScreenshotHotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="1" Content="↺" Click="ResetScreenshotHotkey_Click"
                                                ToolTipService.ToolTip="Reset to Print Screen"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="6,4" MinWidth="0" MinHeight="0" FontSize="14"
                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                    <ComboBox Grid.Row="1" Grid.Column="2" x:Name="PerGameScreenshotCombo" x:FieldModifier="internal"
                                              FontSize="12" MinWidth="60"
                                              ToolTipService.ToolTip="When On, each game gets its own screenshot subfolder."
                                              SelectionChanged="PerGameScreenshotCombo_SelectionChanged">
                                        <ComboBoxItem Content="Off"/>
                                        <ComboBoxItem Content="On"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Row 2 Right: HDR Auto-Toggle + Select Monitors -->
                                <Grid Grid.Row="2" Grid.Column="2" ColumnSpacing="6" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="HDR Auto-Toggle" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="HdrAutoToggleCombo" x:FieldModifier="internal"
                                              FontSize="12" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                              ToolTipService.ToolTip="When On, Windows HDR is automatically enabled when launching a game through RHI and disabled when the game exits."
                                              SelectionChanged="HdrAutoToggleCombo_SelectionChanged">
                                        <ComboBoxItem Content="Off"/>
                                        <ComboBoxItem Content="On"/>
                                    </ComboBox>
                                    <Button Grid.Column="2" Content="⚙" Click="HdrSelectMonitors_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource ChipTextBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8,4" MinWidth="0" MinHeight="0"
                                            FontSize="12" VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Select which monitors to enable HDR on. Empty = primary display only."/>
                                </Grid>

                                <!-- Row 3: Apply buttons -->
                                <Button Grid.Row="3" Grid.Column="0" x:Name="ApplyHotkeyBtn" x:FieldModifier="internal"
                                        Content="Apply to All Games"
                                        Click="ApplyReShadeHotkeys_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>

                                <Button Grid.Row="3" Grid.Column="2" x:Name="ApplyScreenshotPathBtn"
                                        Content="Apply to All Games"
                                        Click="ApplyScreenshotPath_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 3: DLSS & STREAMLINE
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="DLSS / Streamline Settings" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Batch Deploy + Defaults (single column, no row split) -->
                                <StackPanel Grid.Column="0" Spacing="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Batch Deploy" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Deploy DLSS and Streamline DLL versions and DLSS presets to multiple games at once. Backs up originals automatically."/>
                                        <Button Content="Batch Deploy" Click="MassDlssDeploy_Click"
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Defaults" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Configure preferred DLSS/Streamline versions, presets, and render scales. Use 'Apply Defaults' in the Nvidia Profile section to stamp these onto any game."/>
                                        <Button Content="Configure Defaults" Click="DlssDefaults_Click"
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                        <StackPanel x:Name="DlssDefaultsSummaryPanel" x:FieldModifier="internal" Spacing="4" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderSubtleBrush}" Margin="16,0"/>

                                <!-- Right: On-Screen Indicator + Auto-Update -->
                                <StackPanel Grid.Column="2" Spacing="8">
                                    <TextBlock Text="On-Screen Indicator" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Controls the DLSS text overlay NVIDIA shows in the corner of games. Global system setting — affects all games. Requires admin."/>
                                    <ComboBox x:Name="DlssIndicatorCombo" x:FieldModifier="internal"
                                              FontSize="12" HorizontalAlignment="Stretch"
                                              SelectionChanged="DlssIndicatorCombo_SelectionChanged">
                                        <ComboBoxItem Content="Enabled"/>
                                        <ComboBoxItem Content="Disabled"/>
                                    </ComboBox>

                                    <TextBlock Text="Auto-Update" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Automatically swap to the newest version when a new release appears. Only affects games currently on the previous latest — manually chosen older versions are left alone."/>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="DLSS" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="AutoUpdateDlssCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      SelectionChanged="AutoUpdateDlssCombo_SelectionChanged">
                                                <ComboBoxItem Content="Off"/>
                                                <ComboBoxItem Content="On"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Streamline" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="AutoUpdateStreamlineCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      SelectionChanged="AutoUpdateStreamlineCombo_SelectionChanged">
                                                <ComboBoxItem Content="Off"/>
                                                <ComboBoxItem Content="On"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 4: GLOBAL NVIDIA DRIVER SETTINGS
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="Global NVIDIA Driver Settings" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column -->
                                <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Top">
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Driver-level settings applied globally via the base NVIDIA profile. Per-game settings are in the Nvidia Profile section of each game's overrides panel."/>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Shader Cache Size" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="ShaderCacheSizeCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Maximum disk space for compiled shader cache. Larger = fewer stutters on revisits. 16GB is the driver default."
                                                      SelectionChanged="ShaderCacheSizeCombo_SelectionChanged"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Shader Pre-Compile" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="ShaderPrecompileCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Auto-compiles shaders in the background when idle. Higher = more CPU usage during idle, faster first-time game loads."
                                                      SelectionChanged="ShaderPrecompileCombo_SelectionChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="G-Sync Mode" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="GSyncModeCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Controls G-Sync/FreeSync variable refresh rate. Fullscreen and Windowed recommended for seamless experience."
                                                      SelectionChanged="GSyncModeCombo_SelectionChanged"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Preferred Refresh Rate" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="PreferredRefreshRateCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Highest available forces your max refresh rate. App Setting lets games choose their own refresh rate."
                                                      SelectionChanged="PreferredRefreshRateCombo_SelectionChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="VSync" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="GlobalVSyncCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Global VSync mode — applies to all games without a per-game override."
                                                      SelectionChanged="GlobalVSyncCombo_SelectionChanged"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch" Margin="12,0,12,0"/>

                                <!-- Right column -->
                                <StackPanel Grid.Column="2" Spacing="12" VerticalAlignment="Top">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="ReBAR" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                                <TextBlock x:Name="ReBarAdminWarning" x:FieldModifier="internal"
                                                           Text="— Admin required" FontSize="11"
                                                           Foreground="{StaticResource AccentAmberBrush}"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                            <ComboBox x:Name="GlobalReBarEnableCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Global Resizable BAR — enables large GPU memory transfers for all games. Requires admin and compatible hardware (RTX 30 Series+)."
                                                      SelectionChanged="GlobalReBarEnableCombo_SelectionChanged"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="ReBAR Size Limit" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                            <ComboBox x:Name="GlobalReBarSizeCombo" x:FieldModifier="internal"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      ToolTipService.ToolTip="Maximum BAR transfer size. 1GB is optimal for most games. Decrease to 512MB if experiencing ReBAR-related stutters."
                                                      SelectionChanged="GlobalReBarSizeCombo_SelectionChanged"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Export Profiles"
                                                Click="ExportNvidiaProfiles_Click"
                                                ToolTipService.ToolTip="Save all per-game NVIDIA profile settings to a backup file."
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                        <Button Grid.Column="1" Content="Import Profiles"
                                                Click="ImportNvidiaProfiles_Click"
                                                ToolTipService.ToolTip="Restore per-game NVIDIA profile settings from a previous export."
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Reset Nvidia Profiles"
                                                Click="ResetAllNvidiaProfiles_Click"
                                                ToolTipService.ToolTip="Removes ALL per-game NVIDIA profile overrides. The global profile will be like new."
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="#CC4444" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                        <Button Grid.Column="1" Content="Clear Shader Cache"
                                                Click="ClearNvidiaShaderCache_Click"
                                                ToolTipService.ToolTip="Deletes the NVIDIA DXCache and GLCache folders. Forces shaders to recompile on next launch."
                                                Background="{StaticResource AccentBlueBgBrush}"
                                                Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="#CC4444" BorderThickness="1"
                                                CornerRadius="8" Padding="12,7" FontSize="12"
                                                HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 5: COMPONENT SETTINGS (ReLimiter + OptiScaler)
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="Component Settings" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Left: ReLimiter -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="ReLimiter" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="ReLimiter OSD hotkey and global feature settings applied to all games."/>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch" Margin="12,0,12,0"/>

                                <!-- Right: OptiScaler -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="OptiScaler" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="GPU type, DLSS input settings, and overlay hotkey for OptiScaler installations."/>
                                </StackPanel>

                                <!-- Row 1 Left: ReLimiter controls -->
                                <Grid Grid.Row="1" Grid.Column="0" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="OSD Key" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="Shared Presets" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}"
                                               Text="DLSS Hooks" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="UlHotkeyBox" x:FieldModifier="internal"
                                             PlaceholderText="Press a key..." IsReadOnly="True"
                                             FontSize="12" MinWidth="80"
                                             Background="{StaticResource SurfaceInputBrush}"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             BorderBrush="{StaticResource BorderSubtleBrush}"
                                             ToolTipService.ToolTip="The key that toggles the ReLimiter OSD overlay in-game."
                                             PreviewKeyDown="UlHotkeyBox_PreviewKeyDown"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="UlSharedPresetsCombo" x:FieldModifier="internal"
                                              FontSize="12" HorizontalAlignment="Stretch"
                                              ToolTipService.ToolTip="When On, all games share the same OSD presets file. When Off, each game has its own presets."
                                              SelectionChanged="UlSharedPresetsCombo_SelectionChanged">
                                        <ComboBoxItem Content="Off"/>
                                        <ComboBoxItem Content="On"/>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="2" x:Name="UlDlssHooksCombo" x:FieldModifier="internal"
                                              FontSize="12" HorizontalAlignment="Stretch"
                                              ToolTipService.ToolTip="Shows DLSS quality mode, render resolution, and active features on the ReLimiter OSD. Disable if experiencing crashes."
                                              SelectionChanged="UlDlssHooksCombo_SelectionChanged">
                                        <ComboBoxItem Content="Off"/>
                                        <ComboBoxItem Content="On"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Row 1 Right: OptiScaler controls -->
                                <Grid Grid.Row="1" Grid.Column="2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Spacing="4">
                                        <TextBlock Text="GPU Type" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                        <ComboBox x:Name="OsGpuCombo" x:FieldModifier="internal"
                                                  FontSize="12" HorizontalAlignment="Stretch"
                                                  Background="{StaticResource SurfaceInputBrush}"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  BorderBrush="{StaticResource BorderSubtleBrush}"
                                                  SelectionChanged="OsGpuCombo_SelectionChanged">
                                            <x:String>NVIDIA</x:String>
                                            <x:String>AMD</x:String>
                                            <x:String>Intel</x:String>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Spacing="4"
                                                x:Name="OsDlssInputsPanel" x:FieldModifier="internal" Visibility="Collapsed">
                                        <TextBlock Text="DLSS Inputs" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"/>
                                        <ComboBox x:Name="OsDlssInputsCombo" x:FieldModifier="internal"
                                                  FontSize="12" HorizontalAlignment="Stretch"
                                                  Background="{StaticResource SurfaceInputBrush}"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  BorderBrush="{StaticResource BorderSubtleBrush}"
                                                  SelectionChanged="OsDlssInputsCombo_SelectionChanged">
                                            <x:String>Yes</x:String>
                                            <x:String>No</x:String>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2 Left: ReLimiter Apply -->
                                <Button Grid.Row="2" Grid.Column="0" x:Name="ApplyUlHotkeyBtn" x:FieldModifier="internal"
                                        Content="Apply to All Games"
                                        Click="ApplyUlOsdHotkey_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>

                                <!-- Row 2 Right: OptiScaler Hotkey + Apply -->
                                <Grid Grid.Row="2" Grid.Column="2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="OsHotkeyCombo" x:FieldModifier="internal"
                                              FontSize="12" HorizontalAlignment="Stretch"
                                              Background="{StaticResource SurfaceInputBrush}"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              BorderBrush="{StaticResource BorderSubtleBrush}"
                                              SelectionChanged="OsHotkeyCombo_SelectionChanged">
                                        <x:String>Insert</x:String>
                                        <x:String>Home</x:String>
                                        <x:String>End</x:String>
                                        <x:String>Delete</x:String>
                                        <x:String>Page Up</x:String>
                                        <x:String>Page Down</x:String>
                                        <x:String>F1</x:String>
                                        <x:String>F2</x:String>
                                        <x:String>F3</x:String>
                                        <x:String>F4</x:String>
                                        <x:String>F5</x:String>
                                        <x:String>F6</x:String>
                                        <x:String>F7</x:String>
                                        <x:String>F8</x:String>
                                        <x:String>F9</x:String>
                                        <x:String>F10</x:String>
                                        <x:String>F11</x:String>
                                        <x:String>F12</x:String>
                                    </ComboBox>
                                    <Button Grid.Column="1" x:Name="ApplyOsHotkeyBtn" x:FieldModifier="internal"
                                            Content="Apply to All Games"
                                            Click="ApplyOsHotkey_Click"
                                            Background="{StaticResource AccentBlueBgBrush}"
                                            Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,7" FontSize="12"
                                            HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 6: SHADERS & ADDONS
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="Shaders &amp; Addons" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Custom Shaders + Cache -->
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Custom Shaders" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Use your own shader and texture files from a custom directory instead of the built-in shader packs."/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Custom Shaders" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Cache All Shaders" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}" Margin="0,0,0,3"/>
                                        <ComboBox Grid.Row="1" Grid.Column="0" x:Name="CustomShadersCombo" x:FieldModifier="internal"
                                                  FontSize="12" HorizontalAlignment="Stretch"
                                                  ToolTipService.ToolTip="When On, deploys shaders and textures from your custom directory instead of the built-in shader packs."
                                                  SelectionChanged="CustomShadersCombo_SelectionChanged">
                                            <ComboBoxItem Content="Off"/>
                                            <ComboBoxItem Content="On"/>
                                        </ComboBox>
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CacheAllShadersCombo" x:FieldModifier="internal"
                                                  FontSize="12" HorizontalAlignment="Stretch"
                                                  ToolTipService.ToolTip="When On, all shader packs are downloaded and cached at startup. When Off, packs are downloaded on demand when needed."
                                                  SelectionChanged="CacheAllShadersCombo_SelectionChanged">
                                            <ComboBoxItem Content="Off"/>
                                            <ComboBoxItem Content="On"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch" Margin="12,0,12,0"/>

                                <!-- Right: Addon Watch Folder -->
                                <StackPanel Grid.Column="2" Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Addon Watch Folder" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="RHI watches this folder for RenoDX addon files (.addon64/.addon32) and archives. Defaults to your Downloads folder."/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AddonWatchFolderBox" x:FieldModifier="internal"
                                                 Grid.Column="0"
                                                 PlaceholderText="Downloads folder (default)"
                                                 FontSize="12"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseAddonWatchFolder_Click"
                                                Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                                        <Button Grid.Column="2" Content="Reset" Click="ResetAddonWatchFolder_Click"
                                                Background="{StaticResource SurfaceInputBrush}" Foreground="{StaticResource TextTertiaryBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════════════
                             CARD 7: UPDATE & DEPLOYMENT
                             ══════════════════════════════════════════════════════════ -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                            <TextBlock Text="Update &amp; Deployment" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
